#include "resource.h"
#include <windows.h>
#include <commctrl.h>

// ==================== SCREEN SAVER DESCRIPTION STRING ====================
// Per the Win32 screensaver spec, ordinal 1 of the string table is the name shown
// in the Control Panel's screen saver list (ignored if the file has a long file name,
// but still correct to provide).
STRINGTABLE
BEGIN
	1, "Wirbelwerk"
END

// ==================== SETTINGS DIALOG ====================
IDD_CONFIGDIALOG DIALOGEX 0, 0, 400, 620
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Wirbelwerk Settings"
FONT 8, "MS Shell Dlg"
BEGIN
	// ---------------- Language ----------------
	LTEXT           "Language:", IDC_LABEL_LANGUAGE, 7, 6, 50, 10
	COMBOBOX        IDC_COMBO_LANGUAGE, 60, 4, 100, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

	// ---------------- Color ----------------
	GROUPBOX        "Color", IDC_GROUP_COLOR, 7, 18, 386, 102

	CONTROL         "Rainbow", IDC_COLOR_RAINBOW, "Button", BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP, 14, 30, 70, 10
	CONTROL         "Single color", IDC_COLOR_SINGLE, "Button", BS_AUTORADIOBUTTON | WS_TABSTOP, 90, 30, 70, 10
	CONTROL         "Color range", IDC_COLOR_RANGE, "Button", BS_AUTORADIOBUTTON | WS_TABSTOP, 166, 30, 70, 10
	PUSHBUTTON      "?", IDC_INFO_COLORMODE, 240, 29, 14, 12, WS_GROUP

	LTEXT           "Single color:", IDC_LABEL_COLOR_SINGLE_DESC, 14, 47, 70, 8
	EDITTEXT        IDC_EDIT_COLOR_SINGLE, 90, 45, 60, 12, ES_AUTOHSCROLL
	CONTROL         "", IDC_SWATCH_SINGLE, "STATIC", SS_LEFT | WS_BORDER, 154, 45, 24, 12
	PUSHBUTTON      "Pick...", IDC_BTN_PICK_SINGLE, 182, 45, 55, 12

	LTEXT           "Range start:", IDC_LABEL_RANGE_START_DESC, 14, 63, 70, 8
	EDITTEXT        IDC_EDIT_COLOR_RANGE_START, 90, 61, 60, 12, ES_AUTOHSCROLL
	CONTROL         "", IDC_SWATCH_RANGE_START, "STATIC", SS_LEFT | WS_BORDER, 154, 61, 24, 12
	PUSHBUTTON      "Pick...", IDC_BTN_PICK_RANGE_START, 182, 61, 55, 12

	LTEXT           "Range end:", IDC_LABEL_RANGE_END_DESC, 14, 79, 70, 8
	EDITTEXT        IDC_EDIT_COLOR_RANGE_END, 90, 77, 60, 12, ES_AUTOHSCROLL
	CONTROL         "", IDC_SWATCH_RANGE_END, "STATIC", SS_LEFT | WS_BORDER, 154, 77, 24, 12
	PUSHBUTTON      "Pick...", IDC_BTN_PICK_RANGE_END, 182, 77, 55, 12

	CONTROL         "Smooth spawn (fade new splats in)", IDC_CHECK_SMOOTH_SPAWN, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 96, 165, 10
	PUSHBUTTON      "?", IDC_INFO_SMOOTHSPAWN, 182, 95, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_SMOOTH_MS, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 200, 94, 130, 14
	LTEXT           "600ms", IDC_LABEL_SMOOTH_MS, 332, 96, 30, 8
	EDITTEXT        IDC_EDIT_SMOOTH_MS, 364, 94, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	// ---------------- Flow ----------------
	GROUPBOX        "Flow", IDC_GROUP_FLOW, 7, 126, 386, 130

	LTEXT           "Vortex strength", IDC_LABEL_CURL_DESC, 14, 140, 100, 8
	PUSHBUTTON      "?", IDC_INFO_CURL, 116, 139, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_CURL, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 138, 160, 14
	LTEXT           "30", IDC_LABEL_CURL, 296, 140, 30, 8
	EDITTEXT        IDC_EDIT_CURL, 328, 138, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	LTEXT           "Velocity decay", IDC_LABEL_VELDISS_DESC, 14, 158, 100, 8
	PUSHBUTTON      "?", IDC_INFO_VELDISS, 116, 157, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_VELDISS, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 156, 160, 14
	LTEXT           "0.20", IDC_LABEL_VELDISS, 296, 158, 30, 8
	EDITTEXT        IDC_EDIT_VELDISS, 328, 156, 28, 12, ES_AUTOHSCROLL

	LTEXT           "Color decay", IDC_LABEL_DENDISS_DESC, 14, 176, 100, 8
	PUSHBUTTON      "?", IDC_INFO_DENDISS, 116, 175, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_DENDISS, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 174, 160, 14
	LTEXT           "1.00", IDC_LABEL_DENDISS, 296, 176, 30, 8
	EDITTEXT        IDC_EDIT_DENDISS, 328, 174, 28, 12, ES_AUTOHSCROLL

	LTEXT           "Pressure", IDC_LABEL_PRESSURE_DESC, 14, 194, 100, 8
	PUSHBUTTON      "?", IDC_INFO_PRESSURE, 116, 193, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_PRESSURE, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 192, 160, 14
	LTEXT           "0.80", IDC_LABEL_PRESSURE, 296, 194, 30, 8
	EDITTEXT        IDC_EDIT_PRESSURE, 328, 192, 28, 12, ES_AUTOHSCROLL

	LTEXT           "Pressure iterations", IDC_LABEL_PRESSITER_DESC, 14, 212, 100, 8
	PUSHBUTTON      "?", IDC_INFO_PRESSITER, 116, 211, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_PRESSITER, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 210, 160, 14
	LTEXT           "20", IDC_LABEL_PRESSITER, 296, 212, 30, 8
	EDITTEXT        IDC_EDIT_PRESSITER, 328, 210, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	// ---------------- Brush ----------------
	GROUPBOX        "Brush", IDC_GROUP_BRUSH, 7, 262, 386, 88

	LTEXT           "Splat size", IDC_LABEL_SPLATRADIUS_DESC, 14, 276, 100, 8
	PUSHBUTTON      "?", IDC_INFO_SPLATRADIUS, 116, 275, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_SPLATRADIUS, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 274, 160, 14
	LTEXT           "0.25", IDC_LABEL_SPLATRADIUS, 296, 276, 30, 8
	EDITTEXT        IDC_EDIT_SPLATRADIUS, 328, 274, 28, 12, ES_AUTOHSCROLL

	LTEXT           "Splat force", IDC_LABEL_SPLATFORCE_DESC, 14, 294, 100, 8
	PUSHBUTTON      "?", IDC_INFO_SPLATFORCE, 116, 293, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_SPLATFORCE, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 292, 160, 14
	LTEXT           "6000", IDC_LABEL_SPLATFORCE, 296, 294, 30, 8
	EDITTEXT        IDC_EDIT_SPLATFORCE, 328, 292, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	LTEXT           "Dye amount", IDC_LABEL_DYEAMOUNT_DESC, 14, 312, 100, 8
	PUSHBUTTON      "?", IDC_INFO_DYEAMOUNT, 116, 311, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_DYEAMOUNT, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 310, 160, 14
	LTEXT           "0.18", IDC_LABEL_DYEAMOUNT, 296, 312, 30, 8
	EDITTEXT        IDC_EDIT_DYEAMOUNT, 328, 310, 28, 12, ES_AUTOHSCROLL

	// ---------------- Quality ----------------
	GROUPBOX        "Quality", IDC_GROUP_QUALITY, 7, 356, 386, 65

	LTEXT           "Simulation:", IDC_LABEL_SIMRES_DESC, 14, 370, 55, 8
	COMBOBOX        IDC_COMBO_SIMRES, 70, 368, 90, 80, CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
	PUSHBUTTON      "?", IDC_INFO_SIMRES, 164, 369, 14, 12, WS_GROUP
	LTEXT           "Dye res.:", IDC_LABEL_DYERES_DESC, 184, 370, 45, 8
	COMBOBOX        IDC_COMBO_DYERES, 230, 368, 90, 80, CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
	PUSHBUTTON      "?", IDC_INFO_DYERES, 324, 369, 14, 12, WS_GROUP

	CONTROL         "3D shading (lighting)", IDC_CHECK_SHADING, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 388, 150, 10
	PUSHBUTTON      "?", IDC_INFO_SHADING, 166, 387, 14, 12, WS_GROUP

	// ---------------- Behavior ----------------
	GROUPBOX        "Behavior", IDC_GROUP_BEHAVIOR, 7, 427, 386, 88

	CONTROL         "Automatic bursts", IDC_CHECK_AUTOBURST, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 440, 100, 10
	PUSHBUTTON      "?", IDC_INFO_AUTOBURST, 116, 439, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_AUTOINTERVAL, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 438, 160, 14
	LTEXT           "2.6s", IDC_LABEL_AUTOINTERVAL, 296, 440, 30, 8
	EDITTEXT        IDC_EDIT_AUTOINTERVAL, 328, 438, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	LTEXT           "FPS limit", IDC_LABEL_FPSLIMIT_DESC, 14, 458, 100, 8
	PUSHBUTTON      "?", IDC_INFO_FPSLIMIT, 116, 457, 14, 12, WS_GROUP
	CONTROL         "", IDC_SLIDER_FPSLIMIT, "msctls_trackbar32", WS_TABSTOP | TBS_AUTOTICKS | TBS_HORZ, 134, 456, 160, 14
	LTEXT           "60", IDC_LABEL_FPSLIMIT, 296, 458, 30, 8
	EDITTEXT        IDC_EDIT_FPSLIMIT, 328, 456, 28, 12, ES_AUTOHSCROLL | ES_NUMBER

	CONTROL         "Run independently on every display", IDC_CHECK_PERMONITOR, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 14, 476, 220, 10
	PUSHBUTTON      "?", IDC_INFO_PERMONITOR, 236, 475, 14, 12, WS_GROUP

	// ---------------- Footer ----------------
	CONTROL         "Config: ", IDC_LABEL_CONFIGPATH, "STATIC", SS_PATHELLIPSIS | SS_LEFTNOWORDWRAP | WS_GROUP, 7, 522, 386, 10

	PUSHBUTTON      "Preview", IDC_BTN_PREVIEW, 7, 538, 80, 16
	PUSHBUTTON      "Defaults", IDC_BTN_DEFAULTS, 92, 538, 80, 16
	DEFPUSHBUTTON   "Save", IDOK, 206, 538, 72, 16
	PUSHBUTTON      "Cancel", IDCANCEL, 282, 538, 68, 16
END
